  "scripts": {
    "frontend": "cd dashtar-admin && npm install -f",
    "backend": "cd dashtar-backend && npm install -f",
    "devfrontend": "cd dashtar-admin && export NODE_OPTIONS=--openssl-legacy-provider && npm start",
    "devbackend": "cd dashtar-backend && npm run dev",
    "install": "concurrently \"npm run frontend\" \"npm run backend\"",
    "dev": "concurrently \"npm run devfrontend\" \"npm run devbackend\""
